{% extends "layouts/page.njk" %}

{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block beforeContent %}
  <nav aria-label="Back">
    {{ govukBackLink({
      text: "Back to standard sets",
      href: "/standards/standard-sets"
    }) }}
  </nav>
{% endblock %}

{% block content %}
  {% if errors %}
    {{ govukErrorSummary({
      titleText: "There is a problem",
      errorList: [
        {
          text: errors.message,
          href: "#"
        }
      ]
    }) }}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-xl">{{ standardSet.name }}</h1>

      <p class="govuk-body">
        Repository: <a href="{{ standardSet.repository_url }}" class="govuk-link" target="_blank" rel="noopener noreferrer">{{ standardSet.repository_url }}</a>
      </p>

      {% if standardSet.standards.length > 0 %}
        {% set rows = [] %}
        {% for standard in standardSet.standards %}
          {% set standardDetails %}
            {{ govukDetails({
              summaryText: standard.text | extractFirstHeader,
              html: standard.text | markdown | safe
            }) }}
          {% endset %}

          {% set classificationTags %}
            {% for classification in standard.classificationNames %}
              {{ govukTag({
                text: classification,
                classes: "govuk-tag--blue govuk-!-margin-right-1"
              }) }}
            {% endfor %}
          {% endset %}

          {% set rows = (rows.push([
            {
              html: standardDetails
            },
            {
              html: classificationTags
            }
          ]), rows) %}
        {% endfor %}

        {{ govukTable({
          head: [
            {
              text: "Standard"
            },
            {
              text: "Classifications"
            }
          ],
          rows: rows
        }) }}
      {% else %}
        <p class="govuk-body">No standards found in this set.</p>
      {% endif %}
    </div>
  </div>
{% endblock %} 